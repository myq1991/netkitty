{
  "name": "@netkitty/iface",
  "version": "1.1.1",
  "description": "Read-only network interface enumeration for Node.js — adapters, IP/MAC addresses and tx/rx statistics (getifaddrs / networkInterfaces) via a native addon.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "gypfile": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "cpp",
    "binding.gyp",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "clean": "shx rm -rf ./dist ./dist-test",
    "clean:cpp": "shx rm -rf ./bindings",
    "build": "npm run clean && tsc -p tsconfig.json",
    "build:cpp": "npm run clean:cpp && node-gyp-build",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "npm run build:test && node --test \"dist-test/**/*.spec.js\"",
    "test:only": "node --test \"dist-test/**/*.spec.js\""
  },
  "keywords": [
    "netkitty",
    "network-interface",
    "network-interfaces",
    "interface",
    "iface",
    "getifaddrs",
    "networkInterfaces",
    "network-adapter",
    "nic",
    "ip-address",
    "mac-address",
    "interface-statistics",
    "tx-rx",
    "network",
    "native-addon",
    "nodejs"
  ],
  "author": "alex.ma",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "shx": "^0.3.4",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "node-addon-api": "^8.3.1",
    "node-gyp-build": "^4.8.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/myq1991/netkitty.git",
    "directory": "packages/iface"
  },
  "homepage": "https://github.com/myq1991/netkitty/tree/main/packages/iface#readme",
  "bugs": "https://github.com/myq1991/netkitty/issues"
}
