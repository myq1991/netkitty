{
  "name": "netkitty",
  "version": "0.0.35",
  "description": "Network toolkit for Node.js — packet encode/decode (180+ protocols incl. industrial/OT), pcap/pcapng read-write, cross-packet analysis, live capture and replay.",
  "main": "dist/codec.js",
  "types": "dist/codec.d.ts",
  "exports": {
    "./capture": {
      "types": "./dist/capture.d.ts",
      "require": "./dist/capture.js"
    },
    "./pcap": {
      "types": "./dist/pcap.d.ts",
      "require": "./dist/pcap.js"
    },
    "./codec": {
      "types": "./dist/codec.d.ts",
      "require": "./dist/codec.js"
    },
    "./analysis": {
      "types": "./dist/analysis.d.ts",
      "require": "./dist/analysis.js"
    },
    "./iface": {
      "types": "./dist/iface.d.ts",
      "require": "./dist/iface.js"
    },
    "./replay": {
      "types": "./dist/replay.d.ts",
      "require": "./dist/replay.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md"
  ],
  "scripts": {
    "clean": "shx rm -rf ./dist ./dist-test",
    "build": "npm run clean && tsc -p tsconfig.json"
  },
  "keywords": [
    "netkitty",
    "network-toolkit",
    "network-tools",
    "packet",
    "pcap",
    "pcapng",
    "packet-capture",
    "packet-analysis",
    "protocol-decoder",
    "packet-decoder",
    "encode",
    "decode",
    "wireshark",
    "tcpdump",
    "deep-packet-inspection",
    "dpi",
    "industrial-protocol",
    "ot",
    "scada",
    "modbus",
    "iec61850",
    "opcua",
    "network"
  ],
  "author": "alex.ma",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@netkitty/analysis": "^0.0.35",
    "@netkitty/capture": "^0.0.35",
    "@netkitty/codec": "^0.0.35",
    "@netkitty/iface": "^0.0.35",
    "@netkitty/pcap": "^0.0.35",
    "@netkitty/pcap-core": "^0.0.35",
    "@netkitty/replay": "^0.0.35"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "reflect-metadata": "^0.2.2",
    "shx": "^0.3.4",
    "typescript": "^5.8.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/myq1991/netkitty.git",
    "directory": "packages/netkitty"
  },
  "homepage": "https://github.com/myq1991/netkitty/tree/main/packages/netkitty#readme",
  "bugs": "https://github.com/myq1991/netkitty/issues"
}
