{
  "name": "netkitty-monorepo",
  "private": true,
  "description": "netkitty monorepo — workspace root for the codec, pcap, pcap-core, analysis, capture and aggregate packages",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "lerna run clean",
    "build": "lerna run build",
    "test": "lerna run test",
    "test:only": "lerna run test:only",
    "bump": "lerna version",
    "release": "npm run build && lerna publish --conventional-commits --no-push"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/myq1991/netkitty.git"
  },
  "author": "alex.ma",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^8.56.0",
    "lerna": "^9.0.7",
    "release-it": "^19.0.4",
    "shx": "^0.3.4",
    "typescript": "^5.8.2"
  }
}
