{
  "name": "@netkitty/pcap-core",
  "version": "1.1.0",
  "description": "Browser-safe, zero-dependency pcap / pcapng / .cap / tcpdump buffer parser and pcap + pcapng generator — format auto-detected by magic number (classic libpcap in both endiannesses and microsecond/nanosecond variants, plus pcapng) — plus a pure-JS LZ4 frame decompressor",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "clean": "shx rm -rf ./dist ./dist-test",
    "build": "npm run clean && tsc -p tsconfig.json",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "npm run build:test && node --test \"dist-test/**/*.spec.js\"",
    "test:only": "node --test \"dist-test/**/*.spec.js\""
  },
  "keywords": [
    "netkitty",
    "pcap",
    "pcapng",
    "cap",
    "tcpdump",
    "libpcap",
    "pcap-parser",
    "packet-capture",
    "capture-file",
    "wireshark",
    "buffer",
    "browser",
    "isomorphic",
    "zero-dependency",
    "lz4",
    "parser",
    "packet",
    "network"
  ],
  "author": "alex.ma",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "shx": "^0.3.4",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "bignumber.js": "^9.1.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/myq1991/netkitty.git",
    "directory": "packages/pcap-core"
  },
  "homepage": "https://github.com/myq1991/netkitty/tree/main/packages/pcap-core#readme",
  "bugs": "https://github.com/myq1991/netkitty/issues"
}
