{
  "name": "@netkitty/pcap-core",
  "version": "0.0.35",
  "description": "Browser-safe pcap/pcapng buffer parsing and generation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md"
  ],
  "scripts": {
    "clean": "shx rm -rf ./dist ./dist-test",
    "build": "npm run clean && tsc -p tsconfig.json",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "npm run build:test && node --test \"dist-test/**/*.spec.js\"",
    "test:only": "node --test \"dist-test/**/*.spec.js\""
  },
  "keywords": [
    "netkitty",
    "pcap",
    "pcapng",
    "parser",
    "wireshark"
  ],
  "author": "alex.ma",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "reflect-metadata": "^0.2.2",
    "shx": "^0.3.4",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "bignumber.js": "^9.1.2"
  }
}
