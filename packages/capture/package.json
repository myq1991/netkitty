{
  "name": "@netkitty/capture",
  "version": "1.0.0",
  "description": "Live network packet capture (sniffer) over libpcap/Npcap via a native Node.js addon.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "gypfile": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "cpp",
    "binding.gyp",
    "README.md",
    "README.zh-CN.md"
  ],
  "scripts": {
    "clean": "shx rm -rf ./dist ./dist-test",
    "clean:cpp": "shx rm -rf ./bindings",
    "build": "npm run clean && tsc -p tsconfig.json",
    "build:cpp": "npm run clean:cpp && node-gyp-build",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "echo \"@netkitty/capture: integration-only tests (need a real network device + privileges) — run 'npm run test:integration'\"",
    "test:integration": "npm run build:test && node --test \"dist-test/**/*.spec.js\"",
    "test:only": "node --test \"dist-test/**/*.spec.js\""
  },
  "keywords": [
    "netkitty",
    "capture",
    "packet-capture",
    "pcap",
    "npcap",
    "libpcap",
    "wpcap",
    "sniffer",
    "packet-sniffer",
    "live-capture",
    "raw-socket",
    "network",
    "wireshark",
    "native-addon",
    "nodejs"
  ],
  "author": "alex.ma",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/sort-array": "^4.1.2",
    "electron": "^35.0.1",
    "reflect-metadata": "^0.2.2",
    "shx": "^0.3.4",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@netkitty/pcap": "^1.0.0",
    "duplexpair": "^1.0.2",
    "is-electron": "^2.2.2",
    "node-addon-api": "^8.3.1",
    "node-gyp-build": "^4.8.4",
    "socket-ipc": "^4.0.2",
    "sort-array": "^5.0.0",
    "xpipe": "^1.0.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/myq1991/netkitty.git",
    "directory": "packages/capture"
  },
  "homepage": "https://github.com/myq1991/netkitty/tree/main/packages/capture#readme",
  "bugs": "https://github.com/myq1991/netkitty/issues"
}
