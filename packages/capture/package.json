{
  "name": "@netkitty/capture",
  "version": "0.0.35",
  "description": "Live network packet capture over libpcap/Npcap via a native addon",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "gypfile": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "cpp",
    "binding.gyp"
  ],
  "scripts": {
    "clean": "shx rm -rf ./dist ./dist-test",
    "clean:cpp": "shx rm -rf ./bindings",
    "build": "npm run clean && tsc -p tsconfig.json",
    "build:cpp": "npm run clean:cpp && node-gyp-build",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "echo \"@netkitty/capture: integration-only tests (need a real network device + privileges) — run 'npm run test:integration'\"",
    "test:integration": "npm run build:test && node --test \"dist-test/**/*.spec.js\"",
    "test:only": "node --test \"dist-test/**/*.spec.js\""
  },
  "keywords": [
    "netkitty",
    "capture",
    "pcap",
    "npcap",
    "libpcap",
    "wireshark"
  ],
  "author": "alex.ma",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/sort-array": "^4.1.2",
    "electron": "^35.0.1",
    "reflect-metadata": "^0.2.2",
    "shx": "^0.3.4",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@netkitty/pcap": "^0.0.35",
    "duplexpair": "^1.0.2",
    "is-electron": "^2.2.2",
    "node-addon-api": "^8.3.1",
    "node-gyp-build": "^4.8.4",
    "socket-ipc": "^4.0.2",
    "sort-array": "^5.0.0",
    "xpipe": "^1.0.8"
  }
}
