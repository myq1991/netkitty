{
  "name": "@netkitty/codec",
  "version": "0.0.35",
  "description": "Schema-driven protocol codec for encoding/decoding packet headers",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "shx rm -rf ./dist ./dist-test",
    "build": "npm run clean && tsc -p tsconfig.json",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "npm run build:test && node --test \"dist-test/**/*.spec.js\"",
    "test:only": "node --test \"dist-test/**/*.spec.js\""
  },
  "keywords": [
    "netkitty",
    "codec",
    "encode",
    "decode",
    "pcap",
    "wireshark"
  ],
  "author": "alex.ma",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ip-address": "^10.0.1",
    "json-schema": "^0.4.0",
    "node-tlv": "^1.5.14"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/node": "^22.13.10",
    "@types/node-tlv": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "shx": "^0.3.4",
    "typescript": "^5.8.2"
  }
}
