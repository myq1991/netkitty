{
  "name": "@netkitty/pcap",
  "version": "1.0.0",
  "description": "Node.js streaming read / write / parse of pcap, pcapng and .cap / tcpdump capture files — format auto-detected by magic number (classic libpcap in both endiannesses and microsecond/nanosecond variants, plus pcapng), with transparent gzip and LZ4 decompression",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md"
  ],
  "scripts": {
    "clean": "shx rm -rf ./dist ./dist-test",
    "build": "npm run clean && tsc -p tsconfig.json",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "npm run build:test && node --test \"dist-test/**/*.spec.js\"",
    "test:only": "node --test \"dist-test/**/*.spec.js\""
  },
  "keywords": [
    "netkitty",
    "pcap",
    "pcapng",
    "cap",
    "tcpdump",
    "libpcap",
    "pcap-parser",
    "packet-capture",
    "capture-file",
    "wireshark",
    "streaming",
    "stream",
    "gzip",
    "lz4",
    "compression",
    "nodejs",
    "network",
    "parser",
    "packet"
  ],
  "author": "alex.ma",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "reflect-metadata": "^0.2.2",
    "shx": "^0.3.4",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@netkitty/pcap-core": "^1.0.0",
    "duplexpair": "^1.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/myq1991/netkitty.git",
    "directory": "packages/pcap"
  },
  "homepage": "https://github.com/myq1991/netkitty/tree/main/packages/pcap#readme",
  "bugs": "https://github.com/myq1991/netkitty/issues"
}
