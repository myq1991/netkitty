{
  "name": "@netkitty/iface",
  "version": "0.0.35",
  "description": "Read-only network interface enumeration, addresses and tx/rx statistics via a native addon (getifaddrs / GetAdaptersAddresses) — lists every interface including down ones, no libpcap/Npcap needed",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "gypfile": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "cpp",
    "binding.gyp",
    "README.md",
    "README.zh-CN.md"
  ],
  "scripts": {
    "clean": "shx rm -rf ./dist ./dist-test",
    "clean:cpp": "shx rm -rf ./bindings",
    "build": "npm run clean && tsc -p tsconfig.json",
    "build:cpp": "npm run clean:cpp && node-gyp-build",
    "build:test": "tsc -p tsconfig.test.json",
    "test": "npm run build:test && node --test \"dist-test/**/*.spec.js\"",
    "test:only": "node --test \"dist-test/**/*.spec.js\""
  },
  "keywords": [
    "netkitty",
    "network",
    "interface",
    "getifaddrs",
    "networkInterfaces",
    "statistics"
  ],
  "author": "alex.ma",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "shx": "^0.3.4",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "node-addon-api": "^8.3.1",
    "node-gyp-build": "^4.8.4"
  }
}
